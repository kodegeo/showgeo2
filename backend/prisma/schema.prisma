model order_items {
  id          String    @id
  orderId     String
  ticketId    String?
  productId   String?
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(10, 2)
  totalPrice  Decimal   @db.Decimal(10, 2)
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  orders      orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
